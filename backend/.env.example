# Purpose: Document local environment variables consumed by the DiscoveryOS backend scaffold.

DISCOVERYOS_APP_NAME=DiscoveryOS Backend
DISCOVERYOS_ENVIRONMENT=development
DISCOVERYOS_LOG_LEVEL=INFO
DISCOVERYOS_API_PREFIX=/api/v1
DISCOVERYOS_DATABASE_URL=sqlite:///./storage/discoveryos.sqlite3
DISCOVERYOS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DISCOVERYOS_REDIS_URL=
DISCOVERYOS_OPENAI_API_KEY=
DISCOVERYOS_OPENAI_MODEL=gpt-5.6
DISCOVERYOS_PIPELINE_MAX_PAPERS=5
