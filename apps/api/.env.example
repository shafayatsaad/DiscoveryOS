# Purpose: Document backend environment variables without storing local secrets.
# Copy this file to .env for local development and override values as needed.

DISCOVERYOS_APP_NAME=DiscoveryOS API
DISCOVERYOS_ENVIRONMENT=development
DISCOVERYOS_DEBUG=true
DISCOVERYOS_API_VERSION=v1
DISCOVERYOS_API_V1_PREFIX=/api/v1
DISCOVERYOS_LOG_LEVEL=INFO
DISCOVERYOS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

