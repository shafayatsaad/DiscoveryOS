# Purpose: Copy to .env for local Docker Compose runs.

# Compose ports
POSTGRES_DB=discoveryos
POSTGRES_USER=discoveryos
POSTGRES_PASSWORD=discoveryos
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=3000

# API runtime
DISCOVERYOS_APP_NAME=DiscoveryOS API
DISCOVERYOS_ENVIRONMENT=development
DISCOVERYOS_DEBUG=true
DISCOVERYOS_API_VERSION=v1
DISCOVERYOS_API_V1_PREFIX=/api/v1
DISCOVERYOS_LOG_LEVEL=INFO
DISCOVERYOS_SQLALCHEMY_ECHO=false
DISCOVERYOS_DEMO_MODE=true
DISCOVERYOS_SEED_DEMO=true

# Optional for live model calls. The deterministic demo does not require this.
DISCOVERYOS_OPENAI_API_KEY=
DISCOVERYOS_OPENAI_BASE_URL=https://api.openai.com/v1
DISCOVERYOS_OPENAI_MODEL=gpt-5.6

# Browser-visible frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_DEVELOPER_MODE=true
